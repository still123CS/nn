<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="quadrotor_detailed_city">
  <option timestep="0.005" iterations="100" tolerance="1e-10">
    <flag contact="enable" energy="enable"/>
  </option>
  <size nconmax="100" njmax="200"/>

  <default>
    <joint damping="0.001" frictionloss="0.001" armature="0.01"/>
    <geom solref="0.02 1" solimp="0.9 0.95 0.01" margin="0.001" friction="0.8 0.01 0.001"/>
