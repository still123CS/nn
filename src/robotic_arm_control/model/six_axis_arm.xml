<mujoco model="six_axis_robotic_arm">
  <compiler angle="degree" inertiafromgeom="true" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" iterations="100" tolerance="1e-6"/>

  <!-- 材质和纹理 -->
  <asset>
    <material name="base_mat" rgba="0.3 0.3 0.3 1"/>
    <material name="link_mat" rgba="0 0 1 0.8"/>
    <material name="end_mat" rgba="1 0 0 0.9"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3"/>
    <material name="floor_mat" texture="grid" texrepeat="10 10" reflectance="0.1"/>
  </asset>

  <!-- 世界体 -->
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular="0.1 0.1 0.1"/>
    <camera name="arm_cam" pos="0 -1.5 1" xyaxes="1 0 0 0 0.5 1"/>
    <geom name="floor" type="plane" size="2 2 0.1" pos="0 0 0" material="floor_mat"/>

    <!-- 基座 -->
    <body name="base" pos="0 0 0">
      <geom name="base_geom" type="box" size="0.15 0.15 0.05" material="base_mat" mass="2"/>
      <joint name="base_joint"/>

      <!-- 关节1 -->
      <body name="link1" pos="0 0 0.1">
        <geom name="link1_geom" type="cylinder" size="0.05 0.1" material="link_mat" pos="0 0 0.1" mass="0.5"/>
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180" damping="0.05" armature="0.01"/>

        <!-- 关节2 -->
        <body name="link2" pos="0 0 0.2">
          <geom name="link2_geom" type="cylinder" size="0.04 0.2" material="link_mat" pos="0.1 0 0" mass="0.4"/>
          <joint name="joint2" type="hinge" axis="0 1 0" range="-90 90" damping="0.05" armature="0.01"/>

          <!-- 关节3 -->
          <body name="link3" pos="0.2 0 0">
            <geom name="link3_geom" type="cylinder" size="0.04 0.18" material="link_mat" pos="0.09 0 0" mass="0.3"/>
            <joint name="joint3" type="hinge" axis="0 1 0" range="-90 90" damping="0.05" armature="0.01"/>

            <!-- 关节4 -->
            <body name="link4" pos="0.18 0 0">
              <geom name="link4_geom" type="cylinder" size="0.03 0.15" material="link_mat" pos="0 0 0.075" mass="0.2"/>
              <joint name="joint4" type="hinge" axis="0 0 1" range="-180 180" damping="0.05" armature="0.01"/>

              <!-- 关节5 -->
              <body name="link5" pos="0 0 0.15">
                <geom name="link5_geom" type="cylinder" size="0.03 0.08" material="link_mat" pos="0 0 0.04" mass="0.1"/>
                <joint name="joint5" type="hinge" axis="0 1 0" range="-90 90" damping="0.05" armature="0.01"/>

                <!-- 关节6（末端执行器） -->
                <body name="link6" pos="0 0 0.08">
                  <geom name="end_effector" type="sphere" size="0.05" material="end_mat" mass="0.05"/>
                  <joint name="joint6" type="hinge" axis="0 0 1" range="-360 360" damping="0.05" armature="0.01"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 控制器（兼容所有MuJoCo版本） -->
  <actuator>
    <position name="act1" joint="joint1" kp="1500" kv="150"/>
    <position name="act2" joint="joint2" kp="1500" kv="150"/>
    <position name="act3" joint="joint3" kp="1500" kv="150"/>
    <position name="act4" joint="joint4" kp="1500" kv="150"/>
    <position name="act5" joint="joint5" kp="1500" kv="150"/>
    <position name="act6" joint="joint6" kp="1500" kv="150"/>
  </actuator>
</mujoco>